{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts", "configs/**/*.ts", "stories/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
